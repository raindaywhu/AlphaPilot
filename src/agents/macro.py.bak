    def _calculate_overall_view(self, result: Dict[str, Any]) -> tuple:
        """
        计算综合宏观观点

        Args:
            result: 分析结果

        Returns:
            (宏观观点, 置信度)
        """
        # 计算经济指标得分
        eco_score = 0.5  # 中性
        eco_indicators = result.get("economic_indicators", {})
        if eco_indicators.get("pmi", {}).get("impact") == "偏多":
            eco_score += 0.1
        if eco_indicators.get("cpi", {}).get("impact") == "中性偏多":
            eco_score += 0.05

        # 计算政策得分
        policy_score = 0.5  # 中性
        policy_analysis = result.get("policy_analysis", {})
        if policy_analysis.get("monetary_policy", {}).get("impact_on_market") == "中性偏多":
            policy_score += 0.1
        if policy_analysis.get("fiscal_policy", {}).get("impact_on_market") == "偏多":
            policy_score += 0.15

        # 计算地缘政治得分
        geo_score = 0.5  # 中性
        geo_analysis = result.get("geopolitical_analysis", {})
        if geo_analysis.get("us_china_relation", {}).get("status") == "竞争中有合作":
            geo_score += 0.05

        # 综合得分
        total_score = eco_score * 0.3 + policy_score * 0.4 + geo_score * 0.3

        # 确定观点
        if total_score > 0.6:
            view = "利好"
        elif total_score < 0.4:
            view = "利空"
        else:
            view = "中性"

        # 置信度
        confidence = min(abs(total_score - 0.5) * 2, 0.8)

        return view, confidence

    def _generate_conclusion(self, result: Dict[str, Any]) -> str:
        """
        生成结论

        Args:
            result: 分析结果

        Returns:
            结论文本
        """
        macro_view = result.get("macro_view", "中性")
        policy_summary = result.get("policy_analysis", {}).get("summary", {})
        geo_summary = result.get("geopolitical_analysis", {}).get("summary", {})

        parts = [f"宏观环境{macro_view}"]

        # 添加政策结论
        policy_overall = policy_summary.get("overall", "")
        if policy_overall:
            parts.append(f"政策环境{policy_overall}")

        # 添加地缘政治结论
        geo_risk = geo_summary.get("overall_risk_level", "")
        if geo_risk:
            parts.append(f"地缘风险{geo_risk}")

        # 添加投资建议
        opportunities = geo_summary.get("opportunities", [])
        if opportunities:
            parts.append(f"关注{'+'.join(opportunities)}等方向")

        return "，".join(parts)


def main():
    """测试宏观分析师 Agent"""
    print("=" * 60)
    print("宏观分析师 Agent 测试")
    print("=" * 60)

    # 创建 Agent
    agent = MacroAnalyst()

    # 分析股票
    result = agent.analyze("SH600519", focus_areas=["货币政策", "财政政策", "国际形势"])

    # 打印结果
    print("\n分析结果:")
    print(json.dumps(result, indent=2, ensure_ascii=False))


if __name__ == "__main__":
    main()