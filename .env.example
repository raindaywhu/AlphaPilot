# AlphaPilot 配置文件
# 复制此文件为 .env 并填入你的配置

# ========== LLM 配置 ==========
# 智谱 AI GLM-5 API Key（必填）
GLM_API_KEY=your_glm_api_key_here

# API 地址（可选，默认为智谱 AI）
GLM_API_BASE=https://coding.dashscope.aliyuncs.com/v1

# 模型名称（可选）
GLM_MODEL=glm-5

# ========== 数据配置 ==========
# Qlib 数据路径（可选）
QLIB_DATA_PATH=~/.qlib/qlib_data/cn_data

# ========== 日志配置 ==========
LOG_LEVEL=INFO